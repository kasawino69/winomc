+def assert_safe_path(root_key, candidate_path):
+    if root_key not in FILE_ROOTS:
+        raise ValueError("Unbekannter Dateibereich.")
+    base_path = os.path.realpath(FILE_ROOTS[root_key]["path"])
+    candidate_path = os.path.realpath(candidate_path)
+    if not is_inside_base(base_path, candidate_path):
+        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
+    return candidate_path
+
+
+def assert_safe_internal_path(base_dir, candidate_path):
+    base_path = os.path.realpath(base_dir)
+    candidate_path = os.path.realpath(candidate_path)
+    if not is_inside_base(base_path, candidate_path):
+        raise ValueError("Interner Pfad außerhalb des erlaubten Bereichs blockiert.")
+    return candidate_path
+
+
+def assert_safe_download_path(candidate_path):
+    candidate_path = os.path.realpath(candidate_path)
+    allowed_bases = [os.path.realpath(info["path"]) for info in FILE_ROOTS.values()]
+    allowed_bases.append(os.path.realpath(tempfile.gettempdir()))
+    for base_path in allowed_bases:
+        if is_inside_base(base_path, candidate_path):
+            return candidate_path
+    raise ValueError("Download-Pfad außerhalb der erlaubten Bereiche blockiert.")
+
+
+def open_safe(root_key, candidate_path, mode, *args, **kwargs):
+    safe_path = assert_safe_path(root_key, candidate_path)
+    return open(safe_path, mode, *args, **kwargs)
+
+
+def open_safe_internal(base_dir, candidate_path, mode, *args, **kwargs):
+    safe_path = assert_safe_internal_path(base_dir, candidate_path)
+    return open(safe_path, mode, *args, **kwargs)
+
+
+def replace_safe(root_key, source_path, target_path):
+    safe_source = assert_safe_path(root_key, source_path)
+    safe_target = assert_safe_path(root_key, target_path)
+    os.replace(safe_source, safe_target)
+
+
+def remove_safe(root_key, candidate_path):
+    safe_path = assert_safe_path(root_key, candidate_path)
+    if os.path.isdir(safe_path) and not os.path.islink(safe_path):
+        shutil.rmtree(safe_path)
+    else:
+        os.remove(safe_path)
+
+
+def remove_safe_internal(base_dir, candidate_path):
+    safe_path = assert_safe_internal_path(base_dir, candidate_path)
+    if os.path.isdir(safe_path) and not os.path.islink(safe_path):
+        shutil.rmtree(safe_path)
+    else:
+        os.remove(safe_path)
+
